#!/usr/bin/env bash
set -euo pipefail

# ─── Colors & markers ────────────────────────────────────────────────────────

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
RESET='\033[0m'

info()  { printf "${CYAN}ℹ %s${RESET}\n" "$*"; }
ok()    { printf "${GREEN}✓ %s${RESET}\n" "$*"; }
warn()  { printf "${YELLOW}⚠ %s${RESET}\n" "$*"; }
err()   { printf "${RED}✗ %s${RESET}\n" "$*"; }
bold()  { printf "${BOLD}%s${RESET}\n" "$*"; }

# ─── Parse arguments ─────────────────────────────────────────────────────────

DRY_RUN=false
VERSION_OVERRIDE=""

for arg in "$@"; do
    case "$arg" in
        --dry-run)
            DRY_RUN=true
            ;;
        -h|--help)
            cat <<'USAGE'
Usage: bin/release [VERSION] [--dry-run]

  bin/release              Release version from Cargo.toml
  bin/release 0.2.0        Override version
  bin/release --dry-run    Validate everything without publishing

Options:
  --dry-run    Run all checks but skip tag creation and release publishing
  -h, --help   Show this help message
USAGE
            exit 0
            ;;
        *)
            VERSION_OVERRIDE="$arg"
            ;;
    esac
done

# ─── Navigate to project root (directory containing Cargo.toml) ──────────────

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$PROJECT_ROOT"

if [[ ! -f Cargo.toml ]]; then
    err "Cargo.toml not found in $PROJECT_ROOT"
    exit 1
fi

# ─── Resolve version ─────────────────────────────────────────────────────────

CARGO_VERSION=$(grep '^version' Cargo.toml | head -1 | sed 's/.*"\(.*\)".*/\1/')

if [[ -n "$VERSION_OVERRIDE" ]]; then
    VERSION="$VERSION_OVERRIDE"
    info "Version override: ${VERSION} (Cargo.toml has ${CARGO_VERSION})"
else
    VERSION="$CARGO_VERSION"
    info "Version from Cargo.toml: ${VERSION}"
fi

TAG="v${VERSION}"

bold ""
bold "══════════════════════════════════════════"
bold "  swaptop release — ${TAG}"
if $DRY_RUN; then
    printf "  ${YELLOW}DRY RUN — nothing will be published${RESET}\n"
fi
bold "══════════════════════════════════════════"
echo ""

# ─── Preflight: required tools ───────────────────────────────────────────────

info "Preflight checks..."

if ! command -v cargo &>/dev/null; then
    err "cargo is not installed (https://rustup.rs)"
    exit 1
fi
ok "cargo found: $(cargo --version)"

if ! command -v gh &>/dev/null; then
    err "gh CLI is not installed (https://cli.github.com)"
    exit 1
fi
ok "gh found: $(gh --version | head -1)"

if ! gh auth status &>/dev/null; then
    err "gh is not authenticated — run 'gh auth login' first"
    exit 1
fi
ok "gh authenticated"

if ! command -v git &>/dev/null; then
    err "git is not installed"
    exit 1
fi
ok "git found: $(git --version)"

echo ""

# ─── Check for uncommitted changes ───────────────────────────────────────────

info "Checking working tree..."

if [[ -n "$(git status --porcelain)" ]]; then
    warn "Working tree has uncommitted changes:"
    git status --short
    echo ""
    warn "Proceeding anyway — make sure this is intentional"
else
    ok "Working tree is clean"
fi

echo ""

# ─── Check if tag already exists ─────────────────────────────────────────────

info "Checking tag ${TAG}..."

if git rev-parse "$TAG" &>/dev/null; then
    err "Tag ${TAG} already exists locally"
    err "Delete it with: git tag -d ${TAG} && git push origin :refs/tags/${TAG}"
    exit 1
fi
ok "Tag ${TAG} is available"

echo ""

# ─── Quality gates ───────────────────────────────────────────────────────────

info "Running quality gates..."
echo ""

info "[1/3] cargo build"
if cargo build; then
    ok "Build succeeded"
else
    err "Build failed — fix errors before releasing"
    exit 1
fi
echo ""

info "[2/3] cargo clippy -- -D warnings"
if cargo clippy -- -D warnings; then
    ok "Clippy passed (zero warnings)"
else
    err "Clippy found warnings — fix them before releasing"
    exit 1
fi
echo ""

info "[3/3] cargo test"
if cargo test; then
    ok "All tests passed"
else
    err "Tests failed — fix them before releasing"
    exit 1
fi
echo ""

bold "──────────────────────────────────────────"
ok "All quality gates passed"
bold "──────────────────────────────────────────"
echo ""

# ─── Dry run bail-out ────────────────────────────────────────────────────────

if $DRY_RUN; then
    bold "──────────────────────────────────────────"
    ok "Dry run complete — all checks passed"
    info "Re-run without --dry-run to publish ${TAG}"
    bold "──────────────────────────────────────────"
    exit 0
fi

# ─── Create and push tag ─────────────────────────────────────────────────────

info "Creating git tag ${TAG}..."
git tag -a "$TAG" -m "Release ${TAG}"
ok "Tag ${TAG} created"

info "Pushing tag ${TAG} to origin..."
git push origin "$TAG"
ok "Tag ${TAG} pushed"

echo ""

# ─── Build release notes ─────────────────────────────────────────────────────

build_release_notes() {
    local notes_file="$1"
    local tag="$2"
    local version="$3"

    echo "## swaptop ${tag}" >> "$notes_file"
    echo "" >> "$notes_file"
    echo "TUI swap/memory manager for Linux." >> "$notes_file"
    echo "" >> "$notes_file"
    echo "### Installation" >> "$notes_file"
    echo "" >> "$notes_file"
    echo "#### From release binary" >> "$notes_file"
    echo "" >> "$notes_file"
    echo '```bash' >> "$notes_file"
    echo "# Download the binary for your platform from the assets below" >> "$notes_file"
    echo "curl -LO https://github.com/ricsdeol/swaptop/releases/download/${tag}/swaptop-x86_64-unknown-linux-gnu.tar.gz" >> "$notes_file"
    echo "tar xzf swaptop-x86_64-unknown-linux-gnu.tar.gz" >> "$notes_file"
    echo "sudo mv swaptop /usr/local/bin/" >> "$notes_file"
    echo '```' >> "$notes_file"
    echo "" >> "$notes_file"
    echo "#### From source" >> "$notes_file"
    echo "" >> "$notes_file"
    echo '```bash' >> "$notes_file"
    echo "cargo install --git https://github.com/ricsdeol/swaptop --tag ${tag}" >> "$notes_file"
    echo '```' >> "$notes_file"
    echo "" >> "$notes_file"
    echo "### Notes" >> "$notes_file"
    echo "" >> "$notes_file"
    echo "> **⏳ Binaries are being built by CI.** Pre-built binaries will appear in the" >> "$notes_file"
    echo "> assets section shortly. If you don't see them yet, check back in a few minutes" >> "$notes_file"
    echo "> or build from source using the instructions above." >> "$notes_file"
    echo "" >> "$notes_file"
    echo "---" >> "$notes_file"
    echo "" >> "$notes_file"
    echo "**Full Changelog**: https://github.com/ricsdeol/swaptop/compare/...${tag}" >> "$notes_file"
}

# ─── Create GitHub release ───────────────────────────────────────────────────

info "Creating GitHub release for ${TAG}..."

NOTES_FILE=$(mktemp)
trap 'rm -f "$NOTES_FILE"' EXIT

build_release_notes "$NOTES_FILE" "$TAG" "$VERSION"

gh release create "$TAG" \
    --title "swaptop ${TAG}" \
    --notes-file "$NOTES_FILE" \
    --latest

ok "GitHub release created for ${TAG}"

echo ""
bold "══════════════════════════════════════════"
ok "Release ${TAG} published successfully! 🚀"
info "CI will build and attach binaries shortly."
info "View release: $(gh release view "$TAG" --json url -q .url)"
bold "══════════════════════════════════════════"
